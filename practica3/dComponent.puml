@startuml ComponentDiagram
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_TOP_DOWN()

Container_Boundary(app, "Aplicacion de escritorio Java") {

    Component(ui, "Interfaz de usuario", "JFrame/Swing", "Gestiona la interaccion con los usuarios y captura eventos del sistema")

    Component(servicioUsuarios, "Servicio de usuarios", "Java", "Contiene la logica de negocio para registro, autenticacion y administracion de usuarios")

    Component(servicioCitas, "Servicio de citas medicas", "Java", "Implementa la logica de negocio para crear, modificar y consultar citas medicas")

    Component(servicioReportes, "Servicio de reportes y auditorias", "Java", "Genera reportes y estadisticas a partir de la informacion almacenada")

    Component(repoUsuarios, "Repositorio de usuarios", "JDBC", "Gestiona el acceso y persistencia de datos relacionados con los usuarios")

    Component(repoCitas, "Repositorio de citas", "JDBC", "Gestiona el acceso y persistencia de datos relacionados con las citas medicas")

    Component(repoReportes, "Repositorio de reportes", "JDBC", "Realiza consultas especializadas para la generacion de reportes y auditorias")

    ComponentDb(db, "Base de datos", "SQLite", "Almacena la informacion persistente del sistema")
}

Rel(ui, servicioUsuarios, "Solicita operaciones de gestion de usuarios")
Rel(ui, servicioCitas, "Solicita operaciones de gestion de citas")
Rel(ui, servicioReportes, "Solicita generacion de reportes")

Rel(servicioUsuarios, repoUsuarios, "Solicita acceso a datos de usuarios")
Rel(servicioCitas, repoCitas, "Solicita acceso a datos de citas")
Rel(servicioReportes, repoReportes, "Solicita consultas para reportes")

Rel(repoUsuarios, db, "Lee y escribe datos", "JDBC")
Rel(repoCitas, db, "Lee y escribe datos", "JDBC")
Rel(repoReportes, db, "Ejecuta consultas especializadas", "JDBC")

@enduml